<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0096A3">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <RelativeLayout
            android:id="@+id/affectum"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="#79B8B3"
            android:padding="16dp">
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"
                android:gravity="center"
                android:text="Affectum"
                android:textColor="#ECF6F6"
                android:textSize="40dp" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/affectumText"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_below="@+id/affectum"
            android:padding="16dp">
            <TextView
                android:id="@+id/nomedia"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="Nome : Data"
                android:textColor="#ECF6F6"
                android:textSize="35dp" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/affectumListView"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/affectumText"
            android:padding="16dp">
            <ListView
                android:id="@+id/lista"
                android:layout_width="match_parent"
                android:layout_height="380dp"
                android:backgroundTint="#90CFCD" />
        </RelativeLayout>

        <RelativeLayout
            android:id="@+id/affectumBotao"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_below="@+id/affectumListView"
            android:padding="16dp"
            android:layout_marginTop="10dp">

            <Button
                android:id="@+id/botaoExportarPdf"
                android:layout_width="300dp"
                android:layout_height="60dp"
                android:layout_centerHorizontal="true"
                android:backgroundTint="#90CFCD"
                android:gravity="center"
                android:text="Exportar PDF"
                android:fontFamily="@font/nixie_one"
                android:textAlignment="center"
                android:textColor="@color/CorLetra"
                android:textSize="22dp"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/voltar"
                android:layout_width="300dp"
                android:layout_height="60dp"
                android:layout_centerHorizontal="true"
                android:layout_below="@+id/botaoExportarPdf"
                android:backgroundTint="#90CFCD"
                android:gravity="center"
                android:text="Voltar"
                android:fontFamily="@font/nixie_one"
                android:textAlignment="center"
                android:textColor="@color/CorLetra"
                android:textSize="25dp"/>

        </RelativeLayout>
    </RelativeLayout>
</ScrollView>