<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/CorFundo"
    tools:context=".view.MainActivity">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">



    <TextView
        android:id="@+id/app_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="44dp"
        android:text="Affectum"
        android:fontFamily="@font/nixie_one"
        android:textColor="@color/CorLetra"
        android:textSize="40sp"
        android:textStyle="bold" />

    <Spinner
        android:id="@+id/spinner"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/app_name"
        android:layout_centerHorizontal="true"
        android:backgroundTint="@color/CorLetra"
        android:textColorHint="@color/CorLetra"
        android:fontFamily="@font/nixie_one"
        android:layout_marginTop="158dp" />

    <EditText
        android:id="@+id/text_box"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/spinner"
        android:layout_marginTop="220dp"
        android:ems="10"
        android:backgroundTint="@color/CorLetra"
        android:textColorHint="@color/CorLetra"
        android:textColor="@color/CorLetra"
        android:hint="Coloque os detalhes"
        android:textSize="28sp"
        android:fontFamily="@font/nixie_one"
        />

    <Button
        android:id="@+id/botaosalvar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@+id/text_box"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="30dp"
        android:backgroundTint="@color/CorSecundaria"
        android:text="Salvar"
        android:textColor="@color/CorLetra"
        android:fontFamily="@font/nixie_one"
        android:textSize="25dp" />

            <Button
                android:id="@+id/voltar"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_below="@+id/botaosalvar"
                android:layout_centerInParent="true"
                android:backgroundTint="@color/CorSecundaria"
                android:fontFamily="@font/nixie_one"
                android:gravity="center"
                android:text="Voltar"
                android:textAlignment="center"
                android:textColor="@color/CorLetra"
                android:textSize="25dp" />
        </RelativeLayout>
</ScrollView>


</RelativeLayout>
