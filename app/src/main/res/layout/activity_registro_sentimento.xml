<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/CorFundo"
    tools:context=".view.RegistroSentimento">

    <ListView
        android:id="@+id/listview"
        android:layout_width="match_parent"
        android:layout_height="382dp"
        android:background="@color/CorFundo"
        android:padding="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/relativeLayout"
        tools:ignore="MissingConstraints" />

    <EditText
        android:id="@+id/editTextText"
        android:layout_width="198dp"
        android:layout_height="44dp"
        android:ems="10"
        android:hint="Escreva aqui"
        android:textColor="@color/CorLetra"
        android:textSize="22sp"
        android:inputType="text"
        app:layout_constraintBottom_toTopOf="@+id/Cadastrar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.497"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/listview"
        app:layout_constraintVertical_bias="0.074" />

    <RelativeLayout
        android:id="@+id/relativeLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        tools:ignore="MissingConstraints">

    </RelativeLayout>

    <Button
        android:id="@+id/Deletar"
        android:layout_width="300dp"
        android:layout_height="46dp"
        android:text="Deletar"
        android:fontFamily="@font/nixie_one"
        android:backgroundTint="#03bb85"
        android:textColor="@color/CorLetra"
        android:textSize="25sp"
        app:layout_constraintBottom_toTopOf="@+id/Cadastrar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.494"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/editTextText"
        app:layout_constraintVertical_bias="1.0"
        tools:ignore="MissingConstraints" />

    <Button
        android:id="@+id/Cadastrar"
        android:layout_width="300dp"
        android:layout_height="46dp"
        android:textColor="@color/CorLetra"
        android:layout_marginBottom="108dp"
        android:text="Cadastrar"
        android:fontFamily="@font/nixie_one"
        android:textSize="25sp"
        android:backgroundTint="#03bb85"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.495"
        app:layout_constraintStart_toStartOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>